{
  "name": "lcca-coding-agent",
  "description": "Coding agent using small-model MCP tools for context-lean I/O",
  "mcpServers": {
    "lcca-context-tools": {
      "command": "uvx",
      "args": ["--from", "./lcca-context-tools", "lcca-context-tools"],
      "env": {
        "LCCA_CONFIG_PATH": "./lcca-context-tools/lcca-config.yaml"
      }
    }
  },
  "allowedTools": [
    "glob",
    "code",
    "write",
    "shell",
    "lcca-context-tools_read_or_summarize",
    "lcca-context-tools_analyze_error",
    "lcca-context-tools_smart_grep"
  ]
}
